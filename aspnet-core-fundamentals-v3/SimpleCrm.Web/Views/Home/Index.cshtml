@using SimpleCrm.Web.Controllers
@model SimpleCrm.Web.Models.HomePageViewModel
@{ 
    ViewBag.Title = "Customers";
    Layout = "_Layout";
}

    <h1>Customers </h1>
    
    <table>
        @foreach (var customer in Model.Customers)
        {
            <tr>
                <td><a href="/home/details/@customer.Id">Details</a></td>
                <td>@Html.ActionLink("View", nameof(HomeController.Details), new { id = customer.Id }) </td>
               
                <td>@customer.FirstName</td>
                <td>@customer.LastName</td>
                <td>@customer.PhoneNumber</td>
            </tr>
        }
    </table>
@section footer{
    <h4>@Model.CurrentMessage</h4>
 }
